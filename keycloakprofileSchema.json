{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Keycloak source profile",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema reference for the source profile document."
    },
    "ClientId": {
      "title": "Client ID",
      "description": "The client identifier used as the base for generated profiles.",
      "type": "string"
    },
    "Description": {
      "title": "Profile description",
      "description": "The description of the profile.",
      "type": "string"
    },
    "Name": {
      "title": "Profile name",
      "description": "The base name of the profile.",
      "type": "string"
    },
    "RootUrl": {
      "title": "Root URL",
      "description": "The root URL of the application.",
      "type": "string"
    },
    "AdminUrl": {
      "title": "Admin URL",
      "description": "The admin URL of the application.",
      "type": "string"
    },
    "BaseUrl": {
      "title": "Base URL",
      "description": "The base URL of the application.",
      "type": "string"
    },
    "ClientAudience": {
      "title": "Client audience",
      "description": "The audience value used by the generated audience protocol mapper.",
      "type": "string"
    },
    "OptionalClientScopes": {
      "title": "Optional client scopes",
      "description": "Optional scopes for the client.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "RedirectUriArray": {
      "title": "Redirect URIs",
      "description": "The allowed redirect URIs. Values are expected to end with /*.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "WebOriginsArray": {
      "title": "Web origins",
      "description": "The allowed web origins. Values must not contain * and must not end with /.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "PostLogoutRedirectUris": {
      "title": "Post logout redirect URIs",
      "description": "The allowed post logout redirect URIs. Values are expected to end with /*.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ProtocolMappers": {
      "title": "Protocol mappers",
      "description": "Optional custom protocol mappers added to frontend or mobile profiles.",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/definitions/SourceProtocolMapper"
      }
    },
    "AcrLoaMap": {
      "title": "ACR LOA map",
      "description": "Optional map of ACR values to LOA levels.",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "DefaultAcr": {
      "title": "Default ACR",
      "description": "Optional default ACR value.",
      "type": [
        "string",
        "null"
      ]
    },
    "DefaultClientScope": {
      "title": "Default client scopes",
      "description": "Additional default client scopes to append to the generated profile.",
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "ClientId",
    "Name",
    "RootUrl",
    "AdminUrl",
    "BaseUrl",
    "ClientAudience",
    "RedirectUriArray",
    "WebOriginsArray",
    "PostLogoutRedirectUris"
  ],
  "definitions": {
    "SourceProtocolMapper": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Name": {
          "title": "Protocol mapper name",
          "type": "string"
        },
        "Protocol": {
          "title": "Protocol",
          "type": "string"
        },
        "ProtocolMapper": {
          "title": "Protocol mapper",
          "type": "string"
        },
        "consentRequired": {
          "title": "Consent required",
          "type": "boolean"
        },
        "Config": {
          "$ref": "#/definitions/SourceConfig"
        }
      },
      "required": [
        "Name",
        "Protocol",
        "ProtocolMapper"
      ]
    },
    "SourceConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "included.client.audience": {
          "title": "Included client audience",
          "type": [
            "string",
            "null"
          ]
        },
        "introspection.token.claim": {
          "title": "Include in introspection token",
          "type": [
            "string",
            "null"
          ]
        },
        "id.token.claim": {
          "title": "Include in ID token",
          "type": [
            "string",
            "null"
          ]
        },
        "access.token.claim": {
          "title": "Include in access token",
          "type": [
            "string",
            "null"
          ]
        },
        "userinfo.token.claim": {
          "title": "Include in user info token",
          "type": [
            "string",
            "null"
          ]
        },
        "lightweight.claim": {
          "title": "Lightweight claim",
          "type": [
            "string",
            "null"
          ]
        },
        "claim.name": {
          "title": "Claim name",
          "type": [
            "string",
            "null"
          ]
        },
        "claim.value": {
          "title": "Claim value",
          "type": [
            "string",
            "null"
          ]
        },
        "jsonType.label": {
          "title": "JSON type label",
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "String",
            "long",
            "int",
            "boolean",
            "double",
            "JSON",
            null
          ]
        },
        "multivalued": {
          "title": "Multivalued",
          "description": "Whether the generated claim is multivalued.",
          "type": [
            "string",
            "null"
          ]
        },
        "access.tokenRequest.claim": {
          "title": "Include in access token request",
          "type": [
            "string",
            "null"
          ]
        },
        "acr.loa.map": {
          "title": "ACR LOA map",
          "type": [
            "string",
            "null"
          ]
        },
        "default.acr.values": {
          "title": "Default ACR values",
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
